    print(f"Endpoints            :")
    print(f"  GET  /health")
    print(f"  GET  /api/model-info")
    print(f"  POST /api/classify-dual          (small+large, pilih BS)")
    print(f"  POST /api/classify/<small|large> (satu model, pilih BS)")
    print(f"  POST /api/classify-batch         (banyak gambar, pilih BS)")
    print(f"  POST /api/classify-folder        (ZIP folder, pilih BS)")
    print("=" * 65)
    # threaded=True wajib agar Flask bisa handle request paralel
    app.run(debug=False, host='0.0.0.0', port=5000, threaded=True)